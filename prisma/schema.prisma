generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id              String   @id @default(cuid())
  username        String   @unique
  password        String
  role            String   @default("user")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  // Rate limiting: null = unlimited
  dailyMessageLimit  Int?
  dailyTokenLimit    Int?
  conversations   Conversation[]
  loginAttempts   LoginAttempt[]
  mcpServers      McpServer[]
  settings        Settings[]
  modelProfiles   ModelProfile[]
  usageRecords    UsageRecord[]
}

model Conversation {
  id           String    @id @default(cuid())
  title        String    @default("New Chat")
  systemPrompt String    @default("")
  profileId    String?
  profile      ModelProfile? @relation(fields: [profileId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]
  userId       String
  user         Account   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id             String       @id @default(cuid())
  role           String
  content        String
  thinking       String       @default("")
  images         String       @default("[]")
  toolCalls      String       @default("[]")
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  editedAt       DateTime?
}

model Settings {
  id     String   @id @default(cuid())
  key    String
  value  String
  userId String
  user   Account  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  ip        String   @default("")
  username  String   @default("")
  success   Boolean  @default(false)
  createdAt DateTime @default(now())
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id])
}

model ModelProfile {
  id          String   @id @default(cuid())
  name        String
  url         String   @default("http://localhost:1234/v1")
  model       String   @default("")
  temperature Float    @default(0.7)
  maxTokens   Int      @default(2048)
  isDefault   Boolean  @default(false)
  userId      String
  user        Account  @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model McpServer {
  id        String   @id @default(cuid())
  name      String
  url       String
  enabled   Boolean  @default(true)
  toolsJson String   @default("[]")
  userId    String
  user      Account  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// One row per user per day. Tracks total messages sent + tokens consumed.
// Used for per-user daily rate limiting.
model UsageRecord {
  id        String   @id @default(cuid())
  userId    String
  user      Account  @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())  // midnight UTC of the day this record covers
  messages  Int      @default(0)
  promptTokens     Int @default(0)
  completionTokens Int @default(0)
  totalTokens      Int @default(0)

  @@unique([userId, date])
}